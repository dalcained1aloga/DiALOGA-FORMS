# VITE_GOOGLE_CLIENT_ID: Google OAuth 2.0 Client ID for frontend sign-in (Google Identity Services).
# Create in Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Add your app origins (e.g. http://localhost:3000, https://your-app.vercel.app) as Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID="your_google_oauth_client_id_here"

# GOOGLE_CLIENT_ID: Same Client ID value as VITE_GOOGLE_CLIENT_ID — used server-side to verify ID tokens.
# GOOGLE_CLIENT_SECRET is NOT required (we verify ID tokens directly, no server-side code exchange).
GOOGLE_CLIENT_ID="your_google_oauth_client_id_here"

# GEMINI_API_KEY: Required for Gemini AI form conversion.
# Set this in Vercel Project Settings → Environment Variables, or in a local .env file.
GEMINI_API_KEY="your_gemini_api_key_here"

# ENABLE_QA_AUDIT: Optional second-pass Gemini QA audit for completeness (default OFF).
# Enable only on Pro plans or when you can afford the extra latency (~30–60s additional).
# ENABLE_QA_AUDIT="true"

# BLOB_READ_WRITE_TOKEN: Required for Vercel Blob client uploads (draft, logo, watermark).
# Vercel injects this automatically when a Blob store is connected to the project.
# For local dev, copy the token from Vercel Project Settings → Storage → your Blob store.
BLOB_READ_WRITE_TOKEN="your_blob_read_write_token_here"
